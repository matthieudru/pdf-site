# Upstash Redis — get these from https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://YOUR_URL.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_TOKEN

# The public URL of your site (used server-side to fetch the count)
# In production on Vercel this is set automatically via VERCEL_URL
NEXT_PUBLIC_BASE_URL=http://localhost:3000
